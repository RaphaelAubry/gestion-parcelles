<%= form_with model: [@contract.becomes(Contract)] do |form| %>
  <%= render "shared/error_messages", resource: @contract %>
  <%= form.hidden_field :type %>

  <input-group data-controller='input-group'>
    <%= form.label :name, "Nom", data: { input_group_target: 'label' } %>
    <%= form.text_field :name,
      data: { input_group_target: 'input',
              action: 'focus->input-group#focusLabel
                      focusout->input-group#focusoutLabel
                      change->input-group#focusLabel'
            }
    %>
  </input-group>

  <input-group data-controller='input-group'>
    <%= form.label :holder, "Titulaire", data: { input_group_target: 'label' } %>
    <%= form.text_field :holder,
      data: { input_group_target: "input",
              action: "focus->input-group#focusLabel \
                      focusout->input-group#focusoutLabel \
                      change->input-group#focusLabel"
            }
    %>
  </input-group> 

  <input-group>
    <%= form.label "date de début", class: "move" %>
    <%= form.date_field :start_date %>
  </input-group>

  <input-group>
    <%= form.label "date de fin", class: "move" %>
    <%= form.date_field :end_date %>
  </input-group>

  <% case @contract.class.name %>
  <% when "MetayageContract" %>
      <input-group>
        <%= form.label "Part en %", class: "move" %>
        <%= form.number_field :quantity, 
          step: 1,
          min: 0,
          max: 100,
          placeholder: "0",
          value: display_quantity(@contract)
        %>
      </input-group>
      <input-group>
        <%= form.label "unité de mesure", class: "move" %>
        <%= form.text_field :unit, value: "Récolte", readonly: true %>
      </input-group>


  <% when "FermageContract" %>
      <input-group>
        <%= form.label "Quantité", class: "move" %>
        <%= form.number_field :quantity,
          step: 1,
          min: 0,
          placeholder: "0",
          value: display_quantity(@contract)
        %>
      </input-group>

      <input-group data-controller='input-group'>
        <%= form.label "unité de mesure", data: { input_group_target: 'label' } %>
        <%= form.text_field :unit,
          data: { input_group_target: 'input',
                  action: 'focus->input-group#focusLabel
                          focusout->input-group#focusoutLabel
                          change->input-group#focusLabel'
                }
        %>
      </input-group>

  <% else %>
    <input-group data-controller='input-group'>
      <%= form.label "Quantité", data: { input_group_target: 'label' } %>
      <%= form.text_field :quantity,
        data: { input_group_target: 'input',
                action: 'focus->input-group#focusLabel
                        focusout->input-group#focusoutLabel
                        change->input-group#focusLabel'
              }
      %>
    </input-group>

    <input-group data-controller='input-group'>
      <%= form.label "unité de mesure", data: { input_group_target: 'label' } %>
      <%= form.text_field :unit,
        data: { input_group_target: 'input',
                action: 'focus->input-group#focusLabel
                        focusout->input-group#focusoutLabel
                        change->input-group#focusLabel'
              }
      %>
    </input-group>
  <% end %> 
  
  <% if action_name == "edit" %>
    <input-group>
      <%= form.label "parcelles associées à ce contrat", class: "move" %>
    </input-group>
    <wrapper-list-item>
      <% if @contract.parcelles.empty? %>
        <p>Aucune parcelle associée à ce contrat</p>
      <% end %>

      <% @contract.parcelles.each do |p| %>
        <list-item>
          <p>
            <%= link_to [p.reference_cadastrale, p.lieu_dit, "#{p.surface} ha"].compact_blank.join(' - '), parcelle_path(p) %>
          </p>
          <p>
            <%= link_to "retirer", 
                          destroy_contract_associated_parcelle_path(@contract.id, p.id), 
                          data: { turbo_method: :delete } %>
          </p>
        </list-item>  
      <% end %>
    </wrapper-list-item>
  <% end %>

  <% if parcelles_availables.empty? %>
    <input-group>
      <%= form.label "parcelles sans contrat", class: "move" %>
    </input-group>
    <p>Aucune parcelle disponible à rattacher à ce contrat</p>
  <% else %>
    <input-group>
      <%= form.label "parcelles sans contrat", class: "move" %>
      <%= form.select :parcelle_ids, parcelles_availables, {}, { multiple: true, size: 10 } %>
    </input-group>
  <% end %>

  <submit-group>
    <%= form.submit 'valider', class: 'button' %>
    <%= link_to "Annuler", contracts_path %>
  </submit-group>
<% end %>