<input-groups data-controller='line line-metayage'>
  <%= line_form.hidden_field :surface, value: line_form.object.surface %>
  <%= line_form.hidden_field :contract_type, value: "MetayageContract" %>
  <input-group>
    <%= line_form.label "Part en %", class: 'move' %>
    <%= line_form.number_field :percentage,
      readonly: true,
      data: { line_metayage_target: 'percentage' } %> 
  </input-group>

  <input-group data-controller='input-group'>
    <%= line_form.label "Quantité", data: { input_group_target: 'label' } %>
    <%= line_form.number_field :quantity,
      data: { input_group_target: 'input',
              action: 'focus->input-group#focusLabel
                      focusout->input-group#focusoutLabel
                      change->input-group#focusLabel
                      change->line-metayage#updateAmount',
              line_metayage_target: 'quantity' } %> 
  </input-group>
  <input-group data-controller='input-group'>
    <%= line_form.label "Prix", data: { input_group_target: 'label' } %>
    <%= line_form.number_field :price,
      step: "0.01",
      data: { input_group_target: 'input',
              action: 'focus->input-group#focusLabel
                      focusout->input-group#focusoutLabel
                      change->input-group#focusLabel
                      change->line-metayage#updateAmount',
              line_metayage_target: 'price' } %> 
  </input-group>
  <input-group>
    <%= line_form.label "Montant", class: 'move' %>
    <%= line_form.number_field :amount,
      readonly: true,
      data: { action: 'change->input-group#focusLabel',
              line_metayage_target: 'amount' } %> 
  </input-group>
  <a data-line-target='button' data-action='click->line#updateLine' data-status='delete'>Supprimer de la facture</a>
  <%= line_form.hidden_field :id %>
  <%= line_form.hidden_field :_destroy, value: false, data: { line_target: "destroy" } %>
</input-groups>