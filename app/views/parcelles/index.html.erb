<container-tableau>
  
  <% if allowed_to?(:edit?, @target_user) %>
    <h3>Mes Parcelles</h3>
  <% else %>
    <h3>Parcelles</h3>
    <h5>partagé par <%= @target_user.email %></h5>
  <% end %>
  
  <%= render partial: 'table', locals: { columns: Parcelle::INSTANCE_VARIABLES - [:polygon], user_id: @target_user.id } %>

  <link-group>
    <% if allowed_to?(:edit?, @target_user) %>
      <%= link_to 'nouvelle parcelle', new_parcelle_path, data: { navbar_target: 'link' } %>
      <%= link_to 'marqueurs', tags_path, data: { navbar_target: 'link' } %>
    <% end %>
    <%= link_to 'exporter le tableau complet vers excel', parcelles_path(user: @target_user, format: :xlsx), data: { navbar_target: 'link' } %>
  </link-group>

  <% if allowed_to?(:edit?, @target_user) %>
    <% if @parcelles.present? %>
    
      <column-options data-controller='preferences'>

        <% (Parcelle::INSTANCE_VARIABLES - [:polygon]).each do |column_name| %>
          <%= form_for @target_user, html: { data: { preferences_target: 'form' } } do |form| %>

            <checkbox-group>
              <% checked = current_user.send([controller_name, column_name].join('_').to_sym) %>
              <% checked = checked.nil? ? true : checked %>
              <%= form.check_box [controller_name, column_name].join('_').to_sym,
                { data: {
                    datatable_target: 'checkbox',
                    preferences_target: 'checkbox',
                    action: 'change->preferences#display change->preferences#submit',
                    column_name: "#{column_name}"
                  },
                  checked: checked
                },
                'true', 'false'
              %>
              <%= form.label I18n.t(column_name), name: column_name,
                data: { datatable_target: 'column' } %>
            </checkbox-group>

          <% end %>
        <% end %>

      </column-options>
    <% end %>
  <% end %>
</container-tableau>